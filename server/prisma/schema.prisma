// พิมพ์เขียวฐานข้อมูลคลังสินค้า — แก้โครงสร้างตารางที่ไฟล์นี้ที่เดียว
// แล้วรัน `npx prisma migrate dev` เพื่อให้ database จริงอัปเดตตาม

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// กลุ่มสินค้า (จากชีต Group Data เดิม 23 กลุ่ม)
model ItemGroup {
  group_id   String  @id // รหัส 2 หลัก เช่น "01" — เป็น text กันเลข 0 นำหน้าหาย
  group_name String
  detail     String?
  items      Item[]

  @@map("item_groups")
}

// ทะเบียนสินค้า (จากชีต Database เดิม 2,383 รายการ)
model Item {
  item_id      String   @id // 5 หลัก เช่น "02001" — 2 ตัวแรกคือกลุ่ม ห้าม reuse รหัสเด็ดขาด
  name         String
  unit         String? // หน่วยนับ
  group_id     String
  latest_cost  Float? // ราคาล่าสุด — ว่างได้ (NULL = ไม่รู้ราคา ไม่ใช่ราคาศูนย์)
  is_asset     Boolean  @default(false)
  storage_type String? // รูปแบบการจัดเก็บ
  vendor       String? // ร้านค้า
  note         String?
  min_stock    Float? // จุดเตือนของใกล้หมด — NULL = ยังไม่ตั้งเกณฑ์ (ตัดสินใจ 8 ก.ค. 2026: ไม่ใช้ default กลางๆ แบบระบบเก่า)
  // เป็น Float เพราะของบางอย่างนับเป็นทศนิยม เช่น สายไฟเป็นเมตร · ป้าย Low Stock ขึ้นเฉพาะตัวที่ตั้งเกณฑ์แล้ว
  image_url    String? // path รูปสินค้าที่อัปโหลด — NULL = ไม่มีรูป หน้าเว็บ generate placeholder จากชื่อเอง (แบบเดียวกับ users.avatarUrl)
  is_active    Boolean  @default(true) // false = ปิดใช้งาน (soft delete) ห้ามลบแถวจริง
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  group        ItemGroup          @relation(fields: [group_id], references: [group_id])
  transactions StockTransaction[]
  requestItems StockRequestItem[]

  @@index([group_id])
  @@map("items")
}

// ทะเบียนคนใช้ระบบ — ตัวตน + บัญชี login (คอลัมน์ auth เติมโดย migration ก.ค. 2026
// ตามการตัดสินใจใน DATABASE.md ข้อ 6: สมัครเอง+รออนุมัติ, role 3 ค่า, ลืมรหัสผ่านผ่านอีเมล)
model User {
  id            Int      @id @default(autoincrement())
  name          String // ชื่อแสดงผล — ตอนสมัครแอป default = username แก้ทีหลังได้
  username      String   @unique
  email         String   @unique // ใช้ยืนยันตอนสมัคร + ลืมรหัสผ่าน
  password_hash String // ผล bcrypt เท่านั้น (มี salt ฝังในตัว) ห้ามเก็บรหัสจริงเด็ดขาด
  role          String   @default("Operator") // Admin | Manager | Operator | Viewer (ข้อ 6.13) — enum จำลอง โค้ดคุมเอง · สมัครใหม่แอปกำหนด Viewer เองทุกครั้ง (default คอลัมน์คงเดิม — เปลี่ยน = migration ที่ไม่ได้อะไร เพราะแอประบุ role ทุกจุดสร้าง)
  status        String   @default("Pending") // Pending | Active | Denied — วงจรอนุมัติบัญชี (login ได้ต้อง Active และ is_active=true)
  avatarUrl     String? // path รูปโปรไฟล์ — NULL/ว่าง = หน้าเว็บ generate รูปจากชื่อเอง
  is_active     Boolean  @default(true) // ปิดใช้งาน = soft delete ห้ามลบแถวจริง (มีประวัติชี้อยู่)
  created_at    DateTime @default(now())

  documents          StockDocument[]      @relation("creator") // ใบที่คนนี้เป็นคนสร้าง
  requestedDocuments StockDocument[]      @relation("requester") // ใบ ISSUE ที่คนนี้เป็นผู้ขอเบิก
  resolvedDocuments  StockDocument[]      @relation("resolver") // ใบที่คนนี้เป็นคนปิด (ยืนยัน/ปฏิเสธ/ยกเลิก)
  transactions       StockTransaction[]
  resetTokens        PasswordResetToken[]
  auditLogs          AuditLog[]

  @@map("users")
}

// โทเคนลืมรหัสผ่าน — เก็บ hash ของโทเคน ไม่เก็บโทเคนจริง (ใครเห็นตารางก็ปลอมลิงก์รีเซ็ตไม่ได้)
model PasswordResetToken {
  token_hash String    @id
  user_id    Int
  expires_at DateTime // หมดอายุเมื่อไหร่ — เกินแล้วต้องถือว่าใช้ไม่ได้
  used_at    DateTime? // NULL = ยังไม่ถูกใช้ · โทเคนใช้ได้ครั้งเดียว
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@map("password_reset_tokens")
}

// บันทึกการกระทำในระบบ (audit trail) — ใครทำอะไรกับอะไรเมื่อไหร่
model AuditLog {
  id          Int      @id @default(autoincrement())
  actor_id    Int? // FK → users — NULL = ไม่รู้ผู้กระทำ (เช่น เหตุการณ์ก่อน login สำเร็จ)
  action      String // เช่น "auth.login", "transaction.resolve" — โค้ดฝั่งแอปกำหนดชุดค่าเอง
  entity_type String? // ประเภทของสิ่งที่ถูกกระทำ เช่น "user", "product", "transaction"
  entity_id   String? // รหัสของสิ่งนั้น — เก็บเป็น text เสมอ (item_id เป็น text)
  details     String? // รายละเอียดเพิ่มเป็น JSON text
  created_at  DateTime @default(now())

  actor User? @relation(fields: [actor_id], references: [id], onDelete: Restrict)

  @@index([actor_id])
  @@map("audit_logs")
}

// หัวใบเอกสารรับเข้า/เบิกออก (header–detail: 1 ใบ = หลายแถวใน stock_transactions)
model StockDocument {
  id           Int       @id @default(autoincrement())
  doc_no       String    @unique // เลขที่ใบ — แอปเป็นคนออกเลข
  doc_type     String // RECEIVE | ISSUE — SQLite ไม่มี enum โค้ดฝั่งแอปต้องคุมค่าเอง
  doc_date     DateTime // วันที่ทางธุรกิจของใบ (แอป copy ลง transaction_date ของลูกทุกแถว)
  status       String // PENDING | CONFIRMED | CANCELLED — ไม่ตั้ง default บังคับแอประบุเสมอ (RECEIVE→CONFIRMED, ISSUE→PENDING) กันคำขอหายเงียบ
  note         String? // หมายเหตุระดับใบ — ใช้เก็บเหตุผลตอนยกเลิก/ปฏิเสธ (ตรงกับ adminMessage ของทรง JSON เดิม)
  project      String? // โปรเจกต์/เหตุผลที่เบิกไปใช้ — ระดับใบ ผู้ขอกรอกตอนสร้างใบ ISSUE (ต้องมีที่เก็บตั้งแต่ PENDING ที่ยังไม่มีแถว transaction) · ตอน confirm แอป copy ลง stock_transactions.project ของลูกทุกแถว · RECEIVE = NULL ได้
  requested_by Int? // ใครขอเบิก (FK→users) — ISSUE บังคับมี, RECEIVE ว่างเสมอ (แอปคุม)
  resolved_by  Int? // ใครปิดใบ (FK→users) — Admin/Manager ยืนยัน/ปฏิเสธได้ทุกใบ · ผู้ขอยกเลิกใบตัวเองได้เฉพาะตอน PENDING (กติกาฉบับแก้ DATABASE.md ข้อ 6)
  resolved_at  DateTime? // เวลาปิดคำขอ (ยืนยันหรือยกเลิกก็นับ)
  created_by   Int? // ใครสร้างใบ — NULL จนกว่าแอปจะมีระบบ login
  created_at   DateTime  @default(now())

  // onDelete: Restrict ทุกตัว — ห้ามลบคนที่มีใบชี้อยู่ (ให้ soft delete แทน) กัน audit trail หาย
  creator      User?              @relation("creator", fields: [created_by], references: [id], onDelete: Restrict)
  requester    User?              @relation("requester", fields: [requested_by], references: [id], onDelete: Restrict)
  resolver     User?              @relation("resolver", fields: [resolved_by], references: [id], onDelete: Restrict)
  requestItems StockRequestItem[]
  transactions StockTransaction[]

  @@index([created_by])
  @@index([requested_by])
  @@index([resolved_by])
  @@map("stock_documents")
}

// รายการเคลื่อนไหวสต็อก — ยอดคงเหลือ = SUM(qty_change) ต่อสินค้า ไม่เก็บยอดซ้ำที่อื่น
model StockTransaction {
  id               Int      @id @default(autoincrement())
  item_id          String
  type             String // OPENING | IN | OUT | ADJUST — SQLite ไม่มี enum โค้ดฝั่งแอปต้องคุมค่าเอง
  qty_change       Float // บวก = เข้า, ลบ = ออก (มีทศนิยมได้ เช่น ของที่นับเป็นเมตร)
  unit_cost        Float?
  project          String?
  note             String?
  transaction_date DateTime
  created_at       DateTime @default(now())
  document_id      Int? // NULL = ไม่ได้เกิดจากใบเอกสาร (OPENING/ADJUST) — IN/OUT ต้องมีใบเสมอ (แอปคุม)
  created_by       Int? // NULL = ไม่รู้คนทำ (ข้อมูลยกมา) — แอปประทับจากคน login ห้ามให้ผู้ใช้เลือกเอง

  // onDelete: Restrict ทั้งคู่ — ห้ามลบใบ/คนที่มีประวัติชี้อยู่ (ให้ soft delete แทน) กัน audit trail หาย
  item     Item           @relation(fields: [item_id], references: [item_id])
  document StockDocument? @relation(fields: [document_id], references: [id], onDelete: Restrict)
  creator  User?          @relation(fields: [created_by], references: [id], onDelete: Restrict)

  @@index([item_id])
  @@index([document_id])
  @@index([created_by])
  @@map("stock_transactions")
}

// รายการที่ขอเบิก (ลูกของใบ ISSUE ที่ยัง PENDING) — พักไว้ที่นี่ ยังไม่แตะยอดคงเหลือ
// พอคนคลังกดยืนยัน แอปจะอ่านตารางนี้ไปสร้าง stock_transactions จริง (ใช้ qty_confirmed) ทีเดียว
model StockRequestItem {
  id            Int     @id @default(autoincrement())
  document_id   Int
  item_id       String
  qty_requested Float // จำนวนที่ผู้เบิกขอตอนกด — เก็บถาวร ห้ามแก้ทับ (อ้างอิงคำขอเดิมย้อนหลังได้)
  qty_confirmed Float? // จำนวนที่คนคลังให้จริงตอนยืนยัน — NULL ตราบใดที่ยัง PENDING/CANCELLED
  note          String?

  // onDelete: Restrict — สอดคล้องกับทั้ง repo: ห้ามลบใบ/สินค้าที่มีรายการชี้อยู่
  document StockDocument @relation(fields: [document_id], references: [id], onDelete: Restrict)
  item     Item          @relation(fields: [item_id], references: [item_id])

  @@index([document_id])
  @@index([item_id])
  @@map("stock_request_items")
}
