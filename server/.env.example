# คัดลอกไฟล์นี้เป็น .env แล้วปรับค่าตามเครื่อง (.env ถูก gitignore — ห้าม commit ค่าจริง)

PORT=5000
JWT_SECRET=ใส่ข้อความสุ่มยาวๆ-ของใครของมัน
FRONTEND_URL=http://localhost:5173

# Bootstrap admin (ใช้ตอนสร้าง admin คนแรกด้วย npm run create-admin)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@wms.local
BOOTSTRAP_ADMIN_PASSWORD=เปลี่ยนก่อนใช้จริง

# Email (ปล่อยว่างได้ ฟีเจอร์อีเมลจะถูกข้าม)
EMAIL_USER=
EMAIL_PASS=

# Database (Prisma) — path เป็น relative จากโฟลเดอร์ server/
# ระหว่างพัฒนาชี้ที่ฐานพัฒนา วันขึ้นระบบจริงค่อยเปลี่ยนเป็นไฟล์ production
DATABASE_URL="file:./warehouse.dev.db"
